# The Docker build sets this to api. Leave it unset for the public demo.
VITE_ACCOUNT_MODE=api

# Use /canvas-atelier/ for GitHub project pages and / for a custom domain.
VITE_BASE_PATH=/

# Docker Compose infrastructure
POSTGRES_DB=canvas_atelier
POSTGRES_USER=atelier
POSTGRES_PASSWORD=replace-with-a-long-random-password
AUTH_ORIGIN=http://localhost:8080
COOKIE_SECURE=false
SESSION_DAYS=30
WEB_PORT=8080
